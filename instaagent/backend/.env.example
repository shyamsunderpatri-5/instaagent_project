# backend/.env.example
# Copy this to .env and fill in all values before starting the server
# Command: cp .env.example .env
# NEVER commit .env to git — it's in .gitignore

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PHOTO APIs ───────────────────────────────────────────────────────────────
# Remove.bg: https://www.remove.bg/dashboard#api-key
REMOVEBG_API_KEY=your_removebg_api_key_here

# Photoroom: https://app.photoroom.com/api → Get API Key
PHOTOROOM_API_KEY=your_photoroom_api_key_here

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_key_here

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# Get bot token from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwxYZ

# Random secret to verify Telegram webhooks — generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here_min_32_chars

# ─── INSTAGRAM / META ─────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Instagram Basic Display
INSTAGRAM_APP_ID=123456789012345
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
INSTAGRAM_REDIRECT_URI=https://your-backend.render.com/api/v1/instagram/callback

# Set this in Meta Developer Console → Webhooks → Verify Token
# Must match exactly what you put in Meta Dashboard
INSTAGRAM_VERIFY_TOKEN=your_instagram_verify_token_here

# ─── RAZORPAY ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Get from: Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → Redis URL
REDIS_URL=rediss://default:your_password@your-db.upstash.io:6379

# ─── APP ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# development | production
ENVIRONMENT=development

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000
