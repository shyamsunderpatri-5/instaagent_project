# ═══════════════════════════════════════════════════════════════════════════════
# InstaAgent — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.venv

# ── Environment Variables (CRITICAL — never commit these) ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.bak
backend/.env
frontend/.env.local

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
.next-boost.json
frontend/node_modules/
node_modules/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.log

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid
/tmp/celerybeat-schedule

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
*.tmp
*.temp

# ── Docker volumes (local dev) ────────────────────────────────────────────────
postgres_data/
redis_data/

# ── Builds ────────────────────────────────────────────────────────────────────
/site
*.egg-info/

# ── Backup folders ────────────────────────────────────────────────────────────
*back up*/
*backup*/
*_backup/

# ── SSL certs (manage via certbot, never commit) ──────────────────────────────
*.pem
*.key
*.crt
*.csr
nginx/ssl/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel